---
import NewLinkButton from "./NewLinkButton.astro";
import ShareButton from "./ShareButton.astro";
import LinkedinIcon from "./icons/LinkedinIcon.astro";
import WhatsappIcon from "./icons/WhatsappIcon.astro";
import XTwitterIcon from "./icons/XTwitterIcon.astro";

const currentUrl = Astro.url;
const links = [
  {
    href: `https://twitter.com/intent/tweet?text=%F0%9F%9A%A8%20Hey!%20Mira%20que%20art%C3%ADculo%20tan%20interesante%3A%0A%0A${currentUrl}/`,
    title: "Sahre on X (Twitter)",
    icon: XTwitterIcon,
  },
  {
    href: `https://www.linkedin.com/shareArticle?mini=true&url=${currentUrl}`,
    title: "Share on Linkedin",
    icon: LinkedinIcon,
  },
  {
    href: `https://wa.me/?text=Hey!%20Mira%20que%20art%C3%ADculo%20tan%20interesante%3A%0A%0A${currentUrl}`,
    title: "Share on Whatsapp",
    icon: WhatsappIcon,
  },
];
---

{
  links.map((link) => (
    <NewLinkButton title={link.title} href={link.href}>
      <link.icon class="h-5 fill-neutral-500 dark:fill-neutral-200" />
    </NewLinkButton>
  ))
}
<ShareButton />
