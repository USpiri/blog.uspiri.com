---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  class?: string;
  id?: string;
}
const { class: className, ...props } = Astro.props;
---

<a
  class={`${className} transition-all hover:scale-105 rounded-md hover:bg-neutral-400/10 active:scale-90`}
  {...props}
>
  <slot />
</a>
