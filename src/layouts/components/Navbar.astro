---
import HomeIcon from "@components/icons/HomeIcon.astro";
import DevlyIcon from "@components/icons/DevlyIcon.astro";
import SearchButton from "./SearchButton.astro";
import ThemeButton from "./ThemeButton.astro";
import LinkButton from "@components/LinkButton.astro";
import Button from "@components/Button.astro";
import MenuIcon from "@components/icons/MenuIcon.astro";
import Link from "@components/Link.astro";
import type { Link as LinkType } from "@utils/models/links.interface";

const currentPath = Astro.url.pathname.split("/")[1];

const nav: LinkType[] = [
  { label: "Blog", path: "/blog" },
  { label: "Collections", path: "/collections" },
  { label: "Snippets", path: "/snippet" },
  { label: "Daily", path: "/daily" },
];
---

<nav
  class="sticky top-0 z-10 flex justify-center bg-neutral-100/50 px-5 text-neutral-600 backdrop-blur-md dark:bg-neutral-950/50 dark:text-neutral-400"
>
  <div
    class="min-h-[3.5rem] w-full max-w-4xl items-center justify-between md:flex"
  >
    <section class="flex h-14 flex-1 items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <DevlyIcon class="h-4" />
        <span class="font-semibold">Uriel Spiridione</span>
      </a>
      <Button
        id="menu"
        aria-label="Menu button"
        class="block fill-neutral-400 hover:fill-cyan-500 md:hidden"
      >
        <MenuIcon class="h-5" />
      </Button>
    </section>
    <section
      class="navmenu-toggle max-h-0 items-center overflow-hidden md:flex md:h-full md:max-h-none"
      id="navmenu-toggle"
    >
      <div
        class="md:items flex flex-col gap-5 pb-5 pt-3 md:flex-row md:gap-2 md:pb-0 md:pt-0"
      >
        <ul class="flex flex-col gap-2 px-5 md:flex-row md:px-0">
          {
            nav.map((item) => (
              <li>
                <Link
                  href={item.path}
                  class="flex px-1.5 py-0.5 font-semibold hover:text-cyan-500"
                >
                  <span
                    class={`${
                      currentPath.includes(item.path.slice(1)) &&
                      "text-cyan-600 transition-all dark:text-neutral-200"
                    } text-sm md:text-base`}
                  >
                    {item.label}
                  </span>
                </Link>
              </li>
            ))
          }
        </ul>
        <div class="flex items-center justify-around gap-2">
          <Link
            href="/"
            class="fill-neutral-400 p-1 hover:fill-cyan-500 md:hidden"
          >
            <HomeIcon class="h-6 md:h-5" />
          </Link>
          <SearchButton />
          <ThemeButton />
        </div>
      </div>
    </section>
  </div>
</nav>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuButton = document.getElementById("menu");
    const toggle = document.getElementById("navmenu-toggle");
    menuButton?.addEventListener("click", () => {
      toggle?.classList.toggle("height-transition");
    });
  });
</script>

<style>
  .navmenu-toggle {
    transition: max-height 0.3s linear;
  }
  .height-transition {
    max-height: 400px;
  }
  .navbar-open {
    @apply border-b;
  }
</style>
